# Temporarily extend module path for bundled find package scripts
set(_vanetza_save_cmake_module_path ${CMAKE_MODULE_PATH})
list(APPEND CMAKE_MODULE_PATH "@PROJECT_SOURCE_DIR@/cmake")

include(CMakeFindDependencyMacro)
find_dependency(Boost @Boost_VERSION_STRING@ CONFIG COMPONENTS date_time)

if(@VANETZA_WITH_GEOGRAPHICLIB@)
    find_dependency(GeographicLib @GeographicLib_VERSION_STRING@)
endif()

if(@CapnProto_FOUND@)
    find_dependency(CapnProto @CapnProto_VERSION@)
endif()

if(@CryptoPP_FOUND@)
    find_dependency(CryptoPP @CryptoPP_VERSION_STRING@)
endif()

if(@OpenSSL_FOUND@)
    # remove patch letter found with OpenSSL 1.x
    string(REGEX REPLACE "[a-z]+$" "" OpenSSL_VERSION_WITHOUT_PATCH @OpenSSL_VERSION@)
    find_dependency(OpenSSL ${OpenSSL_VERSION_WITHOUT_PATCH})
endif()

# Restore previous module path
set(CMAKE_MODULE_PATH ${_vanetza_save_cmake_module_path})
unset(_vanetza_save_cmake_module_path)

include("${CMAKE_CURRENT_LIST_DIR}/VanetzaExports.cmake")
